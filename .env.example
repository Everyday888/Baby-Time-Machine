# Flask
SECRET_KEY=change-me-to-a-long-random-string

# MySQL — 数据库容器的密码，两个地方保持一致
MYSQL_ROOT_PASSWORD=strongrootpassword
MYSQL_DB=baby_time_machine
MYSQL_USER=btm_user
MYSQL_PASSWORD=stronguserpassword

# 公网访问地址（用于二维码链接），例如 http://58.87.70.226:5000 或 https://example.com
# 如果不填则自动使用 Flask request.host_url（仅 localhost 时有效）
PUBLIC_BASE_URL=

# SMTP 邮件服务（用于找回密码，可选填）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
